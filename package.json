{
  "name": "mappa-territori",
  "private": true,
  "version": "1.0.14",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:sync": "npx cap sync android",
    "apk:debug": "node scripts/bump-version.mjs && npm run build && npx cap sync android && cd android && gradlew assembleDebug && cd .. && node scripts/copy-apk.mjs",
